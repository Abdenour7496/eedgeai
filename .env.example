# Copy this file to .env and fill in your values
# cp .env.example .env

# ── AI Provider keys ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ── Proxy / RAG configuration ─────────────────────────────────────────────────
# Which LLM to use when the model is "openclaw" (the default OpenWebUI model)
# "openai" → uses OPENAI_CHAT_MODEL   "anthropic" → uses ANTHROPIC_CHAT_MODEL
LLM_BACKEND=openai
OPENAI_CHAT_MODEL=gpt-4o
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# Embedding model used for Qdrant semantic search
EMBEDDING_MODEL=text-embedding-3-small

# Qdrant collection to search for RAG context (must match the collection used in ingest.py)
QDRANT_COLLECTION=documents
QDRANT_TOP_K=5

# Set to "false" to disable RAG and use the LLM directly (useful for debugging)
ENABLE_RAG=true

# ── OpenClaw gateway ──────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token
OPENCLAW_GATEWAY_PASSWORD=your-openclaw-gateway-password

# Optional overrides (defaults shown)
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BRIDGE_PORT=18790
# OPENCLAW_GATEWAY_BIND=lan
# OPENCLAW_CONFIG_DIR=openclaw_config
# OPENCLAW_DOCKER_APT_PACKAGES=
